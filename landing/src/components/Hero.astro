---
import ArrowRight from '../icons/ArrowRight.astro';
import ArrowDown from '../icons/ArrowDown.astro';

const APP_URL = 'https://app.blindbench.dev';
---

<section class="relative overflow-hidden">
  <!-- Aurora wash — three slowly-drifting radial layers in the brand purple-blue.
       Pure CSS, no JS, ~0KB perf cost. Respects prefers-reduced-motion. -->
  <div class="aurora-wash pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="aurora-layer aurora-layer-1"></div>
    <div class="aurora-layer aurora-layer-2"></div>
    <div class="aurora-layer aurora-layer-3"></div>
  </div>

  <div class="mx-auto max-w-5xl px-4 pt-32 pb-20 sm:px-6 lg:px-8 lg:pt-44 lg:pb-24">
    <div class="hero-animate mx-auto max-w-3xl text-center">
      <h1
        class="text-[2.5rem] font-extrabold leading-[1.08] tracking-tighter text-foreground sm:text-5xl lg:text-[3.75rem] xl:text-[4.25rem]"
      >
        Get real human feedback on every prompt you&nbsp;ship.
      </h1>

      <p class="mx-auto mt-6 max-w-xl text-lg font-normal leading-relaxed text-muted-foreground sm:text-xl">
        Share one link. Experts, teammates, or customers annotate. The
        optimizer turns their feedback into a better prompt.
      </p>

      <div class="mt-12 flex flex-col items-center gap-4 sm:flex-row sm:justify-center">
        <a
          href={APP_URL}
          class="inline-flex items-center justify-center rounded-lg bg-foreground px-8 py-3.5 text-base font-semibold text-background shadow-md transition-[box-shadow,opacity] hover:shadow-lg hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
        >
          Collect your first feedback
          <ArrowRight class="ml-2 h-4 w-4" />
        </a>
        <a
          href="#how-it-works"
          class="inline-flex items-center justify-center rounded-lg px-8 py-3.5 text-base font-medium text-muted-foreground transition-colors hover:text-foreground focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
        >
          See the loop
          <ArrowDown class="ml-1.5 h-4 w-4" />
        </a>
      </div>

      <p class="mt-5 text-sm text-muted-foreground">
        Bring your own OpenRouter key. No per-seat billing. No credit card.
      </p>
    </div>
  </div>
</section>
