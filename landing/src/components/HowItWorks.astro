---
import StepCard from './StepCard.astro';
import Pencil from '../icons/Pencil.astro';
import Share from '../icons/Share.astro';
import Sparkles from '../icons/Sparkles.astro';

// Three steps — the actual pitch. Create+Run fold into Set up; the pitch
// (share + apply) maps onto ProductDemo and OptimizerDiff as proof below.
const steps = [
  {
    number: 1,
    title: 'Set up',
    description:
      'Write your prompt and pick the models you want to compare. About five minutes of setup.',
    Icon: Pencil,
    color: 'var(--step-1)',
  },
  {
    number: 2,
    title: 'Share one link',
    description:
      'Send one link to whoever should weigh in. They annotate outputs in the browser without signing up.',
    Icon: Share,
    color: 'var(--step-2)',
  },
  {
    number: 3,
    title: 'Apply the feedback',
    description:
      'The optimizer turns those annotations into concrete prompt edits, each one linked back to the comment behind it.',
    Icon: Sparkles,
    color: 'var(--step-3)',
  },
];
---

<section id="how-it-works" class="scroll-mt-16 py-16 lg:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
        How Blind Bench works
      </h2>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground sm:text-lg">
        A short setup on your end, a link for your reviewers, and
        annotations that turn straight into prompt edits.
      </p>
    </div>

    <div class="relative mt-16">
      <!-- Connector line (desktop only) -->
      <div
        class="connector-line absolute top-6 right-0 left-0 hidden h-px bg-border lg:block"
        aria-hidden="true"
      >
      </div>

      <div
        class="grid grid-cols-1 gap-12 sm:grid-cols-3 lg:gap-10"
      >
        {steps.map(({ Icon, ...rest }, i) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <StepCard {...rest}>
              <Icon slot="icon" class="h-4 w-4" />
            </StepCard>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
