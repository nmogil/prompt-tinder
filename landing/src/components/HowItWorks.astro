---
import StepCard from './StepCard.astro';

// Lucide icon paths (pencil, play, eye-off, sparkles)
// Colors use CSS custom properties for theme-aware step differentiation
const steps = [
  {
    number: 1,
    title: 'Create',
    description:
      'Write your prompt with variables and test cases that cover real scenarios.',
    icon: '<path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z" /><path d="m15 5 4 4" />',
    color: 'var(--step-1)',
  },
  {
    number: 2,
    title: 'Run',
    description:
      'Execute against multiple models simultaneously — A/B/C fan-out in one click.',
    icon: '<polygon points="6 3 20 12 6 21 6 3" />',
    color: 'var(--step-2)',
  },
  {
    number: 3,
    title: 'Evaluate blind',
    description:
      'Reviewers see outputs labeled A, B, C — never which version or model wrote them.',
    icon: '<path d="M10.733 5.076a10.744 10.744 0 0 1 11.205 6.575 1 1 0 0 1 0 .696 10.747 10.747 0 0 1-1.444 2.49" /><path d="M14.084 14.158a3 3 0 0 1-4.242-4.242" /><path d="M17.479 17.499a10.75 10.75 0 0 1-15.417-5.151 1 1 0 0 1 0-.696 10.75 10.75 0 0 1 4.446-5.143" /><path d="m2 2 20 20" />',
    color: 'var(--step-3)',
  },
  {
    number: 4,
    title: 'Optimize',
    description:
      'AI reads your annotations and rewrites the prompt, citing specific feedback.',
    icon: '<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z" /><path d="M20 3v4" /><path d="M22 5h-4" />',
    color: 'var(--step-4)',
  },
];
---

<section id="how-it-works" class="py-16 lg:py-24">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-2xl text-center">
      <h2 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
        How it works
      </h2>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground sm:text-lg">
        From first draft to optimized prompt in four steps.
      </p>
    </div>

    <div class="relative mt-16">
      <!-- Connector line (desktop only) -->
      <div
        class="connector-line absolute top-6 right-0 left-0 hidden h-px bg-border lg:block"
        aria-hidden="true"
      >
      </div>

      <div
        class="grid grid-cols-1 gap-12 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8"
      >
        {steps.map((step, i) => (
          <div class={`reveal reveal-delay-${i + 1}`}>
            <StepCard {...step} />
          </div>
        ))}
      </div>
    </div>

    <div class="reveal mt-12 text-center">
      <a
        href="https://app.blindbench.dev"
        class="inline-flex items-center gap-1.5 rounded-md py-2 text-sm font-medium text-primary transition-colors hover:text-primary/80 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
      >
        Try the full workflow
        <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14" /><path d="m12 5 7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</section>
