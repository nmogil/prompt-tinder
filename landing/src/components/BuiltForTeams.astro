---
const capabilities = [
  {
    title: 'Experts',
    description:
      'Your lawyer, doctor, or domain expert annotates in five minutes — without ever seeing your prompt.',
  },
  {
    title: 'Teammates',
    description:
      'Evaluators see outputs, not prompts — so feedback is about the writing, not the author.',
  },
  {
    title: 'Customers',
    description:
      'Embed evaluator links in your product or emails. Real users, reacting to real outputs.',
  },
];
---

<section class="py-12 lg:py-20">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-5 lg:gap-16">
      <div class="reveal lg:col-span-2">
        <h2 class="text-xl font-semibold tracking-tight text-foreground sm:text-2xl">
          The feedback is already out there.
        </h2>
        <p class="mt-4 text-base leading-relaxed text-muted-foreground">
          Your expert has opinions. Your support lead has examples. Your
          customers have reactions. Blind Bench pulls it all in.
        </p>
      </div>

      <div class="space-y-8 lg:col-span-3">
        {
          capabilities.map((cap) => (
            <div>
              <h3 class="text-sm font-semibold text-foreground uppercase tracking-wide">
                {cap.title}
              </h3>
              <p class="mt-1 text-sm leading-relaxed text-muted-foreground">
                {cap.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
