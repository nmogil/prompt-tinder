---
import ArrowRight from '../icons/ArrowRight.astro';

const APP_URL = 'https://app.blindbench.dev';
const year = new Date().getFullYear();
---

<section class="border-t border-border/50 bg-muted/30 py-16 lg:py-24">
  <div class="mx-auto max-w-3xl px-4 text-center sm:px-6 lg:px-8">
    <h2 class="text-xl font-semibold tracking-tight text-foreground sm:text-2xl">
      Stop shipping prompts blind.
    </h2>
    <p class="mt-4 text-base leading-relaxed text-muted-foreground">
      Real humans in the loop. First setup takes five minutes.
    </p>
    <div class="mt-8">
      <a
        href={APP_URL}
        class="inline-flex items-center justify-center rounded-lg bg-foreground px-8 py-3.5 text-base font-semibold text-background shadow-md transition-[box-shadow,opacity] hover:shadow-lg hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
      >
        Collect your first feedback
        <ArrowRight class="ml-2 h-4 w-4" />
      </a>
    </div>
  </div>
</section>

<footer class="border-t border-border py-8">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <p class="text-center text-sm text-muted-foreground">
      &copy; {year} Blind Bench &middot; Built by Mogil Ventures
    </p>
  </div>
</footer>
