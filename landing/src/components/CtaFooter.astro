---
import ArrowRight from '../icons/ArrowRight.astro';

const APP_URL = 'https://app.blindbench.dev';
const CONTACT_EMAIL = 'hello@blindbench.dev';
const year = new Date().getFullYear();
---

<section class="border-t border-border/50 bg-muted/30 py-20 lg:py-28">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl">
      <h2
        class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl"
      >
        Put a human in the loop before your prompts reach users.
      </h2>
      <p class="mt-4 text-base text-muted-foreground">
        Five minutes to set up. BYOK. No credit card.
      </p>
      <div
        class="mt-8 flex flex-col items-start gap-3 sm:flex-row sm:items-center sm:gap-4"
      >
        <a
          href={APP_URL}
          class="inline-flex items-center justify-center rounded-md bg-foreground px-6 py-3 text-sm font-semibold text-background transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
        >
          Get started
          <ArrowRight class="ml-2 h-4 w-4" />
        </a>
        <a
          href={`mailto:${CONTACT_EMAIL}`}
          class="inline-flex items-center justify-center rounded-md border border-border px-6 py-3 text-sm font-medium text-foreground transition-colors hover:bg-muted/60 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
        >
          Talk to the team
        </a>
      </div>
    </div>
  </div>
</section>

<footer class="border-t border-border/70 py-14 lg:py-16">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4 md:gap-10">
      <div class="col-span-2 md:col-span-1">
        <div class="flex items-center gap-2.5">
          <svg
            width="22"
            height="22"
            viewBox="0 0 24 24"
            aria-hidden="true"
            class="text-primary"
          >
            <rect
              x="0.75"
              y="0.75"
              width="22.5"
              height="22.5"
              rx="5.25"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
            />
            <path
              d="M0.75 6A5.25 5.25 0 0 1 6 0.75h6v22.5H6A5.25 5.25 0 0 1 0.75 18Z"
              fill="currentColor"
            />
            <line
              x1="12"
              y1="0.75"
              x2="12"
              y2="23.25"
              stroke="currentColor"
              stroke-width="1"
              opacity="0.9"
            />
          </svg>
          <span class="text-sm font-semibold text-foreground">Blind Bench</span>
        </div>
        <p
          class="mt-4 max-w-[16rem] text-xs leading-relaxed text-muted-foreground"
        >
          Blind human evaluation for production LLM prompts.
        </p>
      </div>

      <div>
        <p
          class="font-mono text-[11px] font-medium tracking-[0.18em] text-foreground uppercase"
        >
          Product
        </p>
        <ul class="mt-5 space-y-3 text-sm">
          <li>
            <a
              href="#how-it-works"
              class="text-muted-foreground transition-colors hover:text-foreground"
              >How it works</a
            >
          </li>
          <li>
            <a
              href="#demo-section"
              class="text-muted-foreground transition-colors hover:text-foreground"
              >Demo</a
            >
          </li>
          <li>
            <a
              href={APP_URL}
              class="text-muted-foreground transition-colors hover:text-foreground"
              >Sign in</a
            >
          </li>
        </ul>
      </div>

      <div>
        <p
          class="font-mono text-[11px] font-medium tracking-[0.18em] text-foreground uppercase"
        >
          Company
        </p>
        <ul class="mt-5 space-y-3 text-sm">
          <li>
            <a
              href={`mailto:${CONTACT_EMAIL}`}
              class="text-muted-foreground transition-colors hover:text-foreground"
              >Contact</a
            >
          </li>
          <li>
            <span class="text-muted-foreground/60">Status</span>
          </li>
        </ul>
      </div>

      <div>
        <p
          class="font-mono text-[11px] font-medium tracking-[0.18em] text-foreground uppercase"
        >
          Legal
        </p>
        <ul class="mt-5 space-y-3 text-sm">
          <li>
            <a
              href={`mailto:${CONTACT_EMAIL}?subject=Privacy%20policy%20request`}
              class="text-muted-foreground transition-colors hover:text-foreground"
              >Privacy</a
            >
          </li>
          <li>
            <a
              href={`mailto:${CONTACT_EMAIL}?subject=Terms%20request`}
              class="text-muted-foreground transition-colors hover:text-foreground"
              >Terms</a
            >
          </li>
          <li>
            <a
              href={`mailto:security@blindbench.dev`}
              class="text-muted-foreground transition-colors hover:text-foreground"
              >Report a vulnerability</a
            >
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col items-start justify-between gap-2 border-t border-border/60 pt-8 sm:flex-row sm:items-center"
    >
      <p class="text-xs text-muted-foreground">
        &copy; {year} Mogil Ventures, LLC. All rights reserved.
      </p>
      <p class="text-xs text-muted-foreground">
        Blind Bench is a product of Mogil Ventures, LLC.
      </p>
    </div>
  </div>
</footer>
