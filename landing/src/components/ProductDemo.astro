---
import ArrowRight from '../icons/ArrowRight.astro';
import User from '../icons/User.astro';

const convexSiteUrl = import.meta.env.PUBLIC_CONVEX_SITE_URL || '';
---

<section class="py-20 lg:py-32" id="demo-section" data-convex-url={convexSiteUrl}>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="reveal mx-auto max-w-2xl text-center mb-10">
      <h2 class="text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
        This is what your reviewers see.
      </h2>
      <p class="mt-4 text-base leading-relaxed text-muted-foreground sm:text-lg">
        Two responses to the same customer. Pick the one you'd send.
      </p>
    </div>

    <!-- Customer message -->
    <div class="reveal mb-6 rounded-xl border border-border bg-muted/50 p-5">
      <div class="flex items-start gap-3">
        <div class="mt-0.5 flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-amber/15">
          <User class="h-4 w-4 text-amber" />
        </div>
        <div>
          <p class="mb-1 text-xs font-medium text-muted-foreground">Customer message</p>
          <p class="text-sm leading-relaxed text-foreground/90">
            &ldquo;Hi, I just noticed I was charged twice for my subscription this month &mdash; $49 on March 3rd and again on March 5th. I&rsquo;ve been a customer for two years and this is really frustrating. Can you help me get this sorted out?&rdquo;
          </p>
        </div>
      </div>
    </div>

    <!-- Demo container -->
    <div class="reveal-scale" id="demo-container">
      <div class="overflow-hidden rounded-2xl border border-border/80 bg-card shadow-2xl ring-1 ring-foreground/5 dark:border-border">
        <!-- Window chrome -->
        <div class="flex items-center gap-2 border-b border-border px-4 py-3">
          <div class="flex gap-1.5">
            <div class="h-2.5 w-2.5 rounded-full bg-border"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-border"></div>
            <div class="h-2.5 w-2.5 rounded-full bg-border"></div>
          </div>
          <div class="ml-4 flex-1">
            <div class="mx-auto w-fit rounded-md bg-muted px-3 py-1 text-xs text-muted-foreground">
              Blind evaluation &mdash; Which response is better?
            </div>
          </div>
        </div>

        <!-- Two-column outputs -->
        <div class="grid grid-cols-1 divide-y divide-border sm:grid-cols-2 sm:divide-x sm:divide-y-0" id="demo-outputs">
          <!-- Output A (secretly: Claude 3.5 Haiku · Prompt v1) -->
          <button
            type="button"
            class="demo-choice p-5 text-left transition-[background-color,opacity,box-shadow] duration-300 hover:bg-muted/30 focus-visible:bg-muted/30 focus-visible:outline-none sm:p-6"
            data-choice="A"
            id="choice-a"
          >
            <div class="mb-4 flex items-center gap-2">
              <span class="demo-blind-label inline-flex h-6 w-6 items-center justify-center rounded-md bg-primary/10 text-xs font-bold text-primary transition-opacity duration-300">A</span>
              <span class="demo-blind-tag text-xs text-muted-foreground transition-opacity duration-300">Output</span>
              <span class="demo-real-label text-xs font-medium text-primary opacity-0 transition-opacity duration-300">Claude 3.5 Haiku &middot; Prompt v1 (first draft)</span>
            </div>
            <p class="text-sm leading-relaxed text-foreground/80">
              I&rsquo;m really sorry about the double charge &mdash; that&rsquo;s completely on us and I understand how frustrating that must be, especially as a long-time customer. I&rsquo;ve just issued a refund for the duplicate $49 charge. You should see it back in your account within 3&ndash;5 business days. If it doesn&rsquo;t show up by then, reply here and I&rsquo;ll escalate it right away.
            </p>
          </button>

          <!-- Output B (secretly: GPT-4o · Prompt v7) -->
          <button
            type="button"
            class="demo-choice p-5 text-left transition-[background-color,opacity,box-shadow] duration-300 hover:bg-muted/30 focus-visible:bg-muted/30 focus-visible:outline-none sm:p-6"
            data-choice="B"
            id="choice-b"
          >
            <div class="mb-4 flex items-center gap-2">
              <span class="demo-blind-label inline-flex h-6 w-6 items-center justify-center rounded-md bg-primary/10 text-xs font-bold text-primary transition-opacity duration-300">B</span>
              <span class="demo-blind-tag text-xs text-muted-foreground transition-opacity duration-300">Output</span>
              <span class="demo-real-label text-xs font-medium text-primary opacity-0 transition-opacity duration-300">GPT-4o &middot; Prompt v7 (12 iterations)</span>
            </div>
            <p class="text-sm leading-relaxed text-foreground/80">
              Thank you for reaching out and for being a valued customer for two years. I&rsquo;ve reviewed your billing history and can confirm that a duplicate charge of $49.00 was processed on March 5th in error. I have initiated a full refund for the erroneous charge, which will be reflected in your statement within 3&ndash;5 business days. Additionally, I have flagged your account to ensure this issue does not recur. Please do not hesitate to contact us should you require any further assistance.
            </p>
          </button>
        </div>

        <!-- Bottom bar -->
        <div class="flex items-center justify-between border-t border-border px-4 py-3 sm:px-6">
          <span class="text-xs text-muted-foreground" id="demo-status">2 outputs &middot; Blind mode</span>
          <span class="text-xs font-medium text-primary transition-opacity duration-300" id="demo-prompt">
            Click the response you&rsquo;d send
          </span>
        </div>
      </div>
    </div>

    <!-- Reveal section (hidden until vote) -->
    <div class="mt-8 text-center transition-[opacity,transform] duration-500" id="demo-reveal" role="status" aria-live="polite" aria-atomic="true" style="opacity:0;transform:translateY(12px)">
      <p class="text-lg font-semibold text-foreground" id="reveal-headline"></p>
      <p class="mt-2 text-sm text-muted-foreground" id="reveal-stats"></p>
      <p class="mx-auto mb-6 mt-6 max-w-lg text-base leading-relaxed text-muted-foreground">
        That&rsquo;s one blind test. Blind Bench makes it the default for every prompt you ship.
      </p>
      <a
        href="https://app.blindbench.dev"
        class="inline-flex items-center gap-2 rounded-lg bg-primary px-5 py-2.5 text-sm font-medium text-primary-foreground shadow-md transition-[box-shadow,opacity] hover:shadow-lg hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
      >
        Collect feedback on your prompts
        <ArrowRight class="h-4 w-4" />
      </a>
    </div>
  </div>
</section>

<style>
  .demo-choice {
    cursor: pointer;
  }

  .demo-choice.voted {
    cursor: default;
  }

  .demo-choice.voted:hover {
    background: transparent;
  }

  .demo-choice.selected {
    box-shadow: inset 0 0 0 2px var(--primary);
  }

  .demo-choice.dimmed {
    opacity: 0.45;
  }

  .demo-choice.revealed .demo-blind-label,
  .demo-choice.revealed .demo-blind-tag {
    opacity: 0;
    position: absolute;
    pointer-events: none;
  }

  .demo-choice.revealed .demo-real-label {
    opacity: 1;
  }
</style>

<script>
  const section = document.getElementById('demo-section');
  const convexUrl = section?.dataset.convexUrl || '';
  const choiceA = document.getElementById('choice-a') as HTMLButtonElement | null;
  const choiceB = document.getElementById('choice-b') as HTMLButtonElement | null;
  const revealSection = document.getElementById('demo-reveal');
  const revealHeadline = document.getElementById('reveal-headline');
  const revealStats = document.getElementById('reveal-stats');
  const demoPrompt = document.getElementById('demo-prompt');

  const STORAGE_KEY = 'bb-demo-vote';
  let hasVoted = false;

  // Check for previous vote
  const previousVote = localStorage.getItem(STORAGE_KEY);
  if (previousVote) {
    hasVoted = true;
    showReveal(previousVote as 'A' | 'B', true);
    loadStats(previousVote as 'A' | 'B');
  }

  function handleVote(choice: 'A' | 'B') {
    if (hasVoted) return;
    hasVoted = true;
    localStorage.setItem(STORAGE_KEY, choice);

    showReveal(choice, false);

    // Send vote to Convex
    if (convexUrl) {
      fetch(`${convexUrl}/api/demo-vote`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ choice }),
      })
        .then((res) => res.json())
        .then((data) => {
          if (data.totalVotes && data.totalVotes > 1) {
            const yourPercent = choice === 'A' ? data.percentA : data.percentB;
            animateCounter(yourPercent, data.totalVotes);
          }
        })
        .catch(() => {
          // Graceful degradation — reveal still works without stats
        });
    }
  }

  function showReveal(choice: 'A' | 'B', instant: boolean) {
    const selected = choice === 'A' ? choiceA : choiceB;
    const other = choice === 'A' ? choiceB : choiceA;

    // Disable hover/click on both
    choiceA?.classList.add('voted');
    choiceB?.classList.add('voted');

    if (instant) {
      // Instant reveal for returning visitors
      selected?.classList.add('selected', 'revealed');
      other?.classList.add('dimmed', 'revealed');
      if (demoPrompt) demoPrompt.style.opacity = '0';
      if (revealHeadline) {
        revealHeadline.textContent =
          choice === 'A'
            ? 'The first draft won.'
            : 'You chose the polished version.';
      }
      if (revealSection) {
        revealSection.style.opacity = '1';
        revealSection.style.transform = 'translateY(0)';
      }
      return;
    }

    // Animated reveal sequence
    // Step 1: highlight selection
    selected?.classList.add('selected');
    other?.classList.add('dimmed');
    if (demoPrompt) demoPrompt.style.opacity = '0';

    // Step 2: reveal model labels
    const revealDelay = window.matchMedia('(prefers-reduced-motion: reduce)').matches ? 0 : 300;
    setTimeout(() => {
      choiceA?.classList.add('revealed');
      choiceB?.classList.add('revealed');
    }, revealDelay);

    // Step 3: show headline + CTA
    setTimeout(
      () => {
        if (revealHeadline) {
          revealHeadline.textContent =
            choice === 'A'
              ? 'The first draft won.'
              : 'You chose the polished version.';
        }
        if (revealSection) {
          revealSection.style.opacity = '1';
          revealSection.style.transform = 'translateY(0)';
        }
      },
      revealDelay + 300,
    );
  }

  function loadStats(choice: 'A' | 'B') {
    if (!convexUrl) return;
    fetch(`${convexUrl}/api/demo-stats`)
      .then((res) => res.json())
      .then((data) => {
        if (data.totalVotes && data.totalVotes > 1) {
          const yourPercent = choice === 'A' ? data.percentA : data.percentB;
          if (revealStats) {
            revealStats.textContent = `${yourPercent}% of visitors made the same choice (${data.totalVotes.toLocaleString()} votes)`;
          }
        }
      })
      .catch(() => {});
  }

  function animateCounter(targetPercent: number, totalVotes: number) {
    if (!revealStats) return;
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (reducedMotion) {
      revealStats.textContent = `${targetPercent}% of visitors made the same choice (${totalVotes.toLocaleString()} votes)`;
      return;
    }

    let current = 0;
    const duration = 500;
    const steps = 20;
    const interval = duration / steps;
    const increment = targetPercent / steps;

    const timer = setInterval(() => {
      current += increment;
      if (current >= targetPercent) {
        current = targetPercent;
        clearInterval(timer);
      }
      revealStats.textContent = `${Math.round(current)}% of visitors made the same choice (${totalVotes.toLocaleString()} votes)`;
    }, interval);
  }

  choiceA?.addEventListener('click', () => handleVote('A'));
  choiceB?.addEventListener('click', () => handleVote('B'));
</script>
