---
interface Props {
  index: number;
  number: number;
  title: string;
  description: string;
  active?: boolean;
  panelId: string;
  tabId: string;
}

const { index, number, title, description, active = false, panelId, tabId } = Astro.props;
---

<button
  type="button"
  class="journey-tab group relative flex flex-col items-start gap-1.5 px-0 py-4 text-left transition-opacity focus-visible:outline-none lg:py-5"
  role="tab"
  id={tabId}
  aria-controls={panelId}
  aria-selected={active ? 'true' : 'false'}
  tabindex={active ? 0 : -1}
  data-journey-tab
  data-index={index}
>
  <div class="flex items-center gap-3">
    <span class="journey-step-num inline-flex h-7 w-7 items-center justify-center rounded-full text-xs font-semibold transition-colors">
      {number}
    </span>
    <h3 class="journey-step-title text-base font-semibold transition-colors sm:text-lg">
      {title}
    </h3>
  </div>
  <p class="journey-step-desc pl-10 text-sm leading-relaxed transition-colors">
    {description}
  </p>
</button>

<style>
  .journey-tab {
    cursor: pointer;
  }

  /* Default (inactive) state */
  .journey-step-num {
    background-color: var(--muted);
    color: var(--muted-foreground);
  }
  .journey-step-title {
    color: var(--muted-foreground);
  }
  .journey-step-desc {
    color: var(--muted-foreground);
  }

  /* Active state */
  .journey-tab[aria-selected='true'] .journey-step-num {
    background-color: var(--primary);
    color: var(--primary-foreground);
  }
  .journey-tab[aria-selected='true'] .journey-step-title {
    color: var(--foreground);
  }
  .journey-tab[aria-selected='true'] .journey-step-desc {
    color: var(--foreground);
    opacity: 0.8;
  }

  /* Hover on inactive — subtle preview */
  .journey-tab[aria-selected='false']:hover .journey-step-title,
  .journey-tab[aria-selected='false']:focus-visible .journey-step-title {
    color: var(--foreground);
  }
  .journey-tab[aria-selected='false']:hover .journey-step-num,
  .journey-tab[aria-selected='false']:focus-visible .journey-step-num {
    background-color: color-mix(in oklch, var(--primary) 20%, var(--muted));
    color: var(--foreground);
  }

  .journey-tab:focus-visible {
    outline: 2px solid var(--ring);
    outline-offset: 4px;
    border-radius: 6px;
  }
</style>
