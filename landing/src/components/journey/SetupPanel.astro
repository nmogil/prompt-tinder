---
import Play from '../../icons/Play.astro';

const models = [
  { name: 'GPT-4o', vendor: 'OpenAI', temp: '0.7' },
  { name: 'Claude 3.5 Haiku', vendor: 'Anthropic', temp: '0.7' },
  { name: 'Gemini 1.5 Pro', vendor: 'Google', temp: '1.0' },
];
---

<div class="mx-auto max-w-4xl">
  <div class="overflow-hidden rounded-2xl border border-border/80 bg-card shadow-2xl ring-1 ring-foreground/5 dark:border-border">
    <!-- Window chrome -->
    <div class="flex items-center gap-2 border-b border-border px-4 py-3">
      <div class="flex gap-1.5" aria-hidden="true">
        <div class="h-2.5 w-2.5 rounded-full bg-border"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-border"></div>
        <div class="h-2.5 w-2.5 rounded-full bg-border"></div>
      </div>
      <div class="ml-4 flex-1">
        <div class="mx-auto w-fit rounded-md bg-muted px-3 py-1 text-xs text-muted-foreground">
          New evaluation &middot; customer-support-tone &middot; v3
        </div>
      </div>
    </div>

    <!-- Two-column: editor + config -->
    <div
      class="grid grid-cols-1 divide-y divide-border lg:grid-cols-[1.5fr_1fr] lg:divide-x lg:divide-y-0"
    >
      <!-- Left: prompt editor -->
      <div class="p-5 sm:p-6">
        <div class="mb-3 flex items-center justify-between gap-2">
          <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">
            System message
          </span>
          <span class="font-mono text-[11px] text-muted-foreground">system.md</span>
        </div>
        <div class="rounded-lg border border-border bg-muted/30 p-4">
          <p class="font-mono text-sm leading-relaxed text-foreground/85">
            You are a customer support agent. <span class="setup-highlight">Be friendly and professional.</span> Respond clearly to the user&rsquo;s message and resolve their issue.
          </p>
        </div>

        <div class="mt-4">
          <div class="mb-2 flex items-center gap-2">
            <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">
              Variables
            </span>
          </div>
          <div class="flex flex-wrap gap-1.5">
            <span class="inline-flex items-center rounded-md border border-border bg-muted/50 px-2 py-1 font-mono text-[11px] text-foreground/80">
              &#123;&#123;customer_message&#125;&#125;
            </span>
            <span class="inline-flex items-center rounded-md border border-border bg-muted/50 px-2 py-1 font-mono text-[11px] text-foreground/80">
              &#123;&#123;account_tier&#125;&#125;
            </span>
          </div>
        </div>
      </div>

      <!-- Right: model slots -->
      <div class="bg-muted/20 p-5 sm:p-6">
        <div class="mb-3 flex items-center justify-between gap-2">
          <span class="text-xs font-medium text-muted-foreground uppercase tracking-wide">
            Model slots
          </span>
          <span class="text-[11px] text-muted-foreground">3 of 6</span>
        </div>
        <div class="space-y-2">
          {
            models.map((m, i) => (
              <div class="rounded-lg border border-border bg-card p-3">
                <div class="flex items-center justify-between gap-2">
                  <div class="flex items-center gap-2 min-w-0">
                    <span class="inline-flex h-5 w-5 flex-shrink-0 items-center justify-center rounded bg-primary/10 text-[10px] font-semibold text-primary">
                      {i + 1}
                    </span>
                    <span class="truncate text-xs font-medium text-foreground">{m.name}</span>
                  </div>
                  <span class="font-mono text-[10px] text-muted-foreground">t={m.temp}</span>
                </div>
                <p class="mt-1 pl-7 text-[10px] text-muted-foreground">{m.vendor}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="flex items-center justify-between border-t border-border px-4 py-3 sm:px-6">
      <span class="text-xs text-muted-foreground">
        6 test cases &middot; BYOK
      </span>
      <span class="inline-flex items-center gap-1.5 rounded-md bg-primary px-3 py-1.5 text-xs font-medium text-primary-foreground shadow-sm">
        <Play class="h-3 w-3" />
        Run evaluation
      </span>
    </div>
  </div>
</div>

<style>
  .setup-highlight {
    background-color: color-mix(in oklch, var(--primary) 15%, transparent);
    color: var(--primary);
    padding: 0.1em 0.25em;
    margin: 0 -0.05em;
    border-radius: 3px;
  }
</style>
